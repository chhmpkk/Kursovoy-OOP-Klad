<Window x:Class="KLAD.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:glWpf="clr-namespace:OpenTK.Wpf;assembly=GLWpfControl"
        xmlns:local="clr-namespace:KLAD"
        mc:Ignorable="d"
        Title="Клад (Treasure Hunt)" Height="600" Width="800">
    <Grid>
        <!-- Слой игры (OpenTK) -->
        <glWpf:GLWpfControl x:Name="OpenTkControl" Render="OpenTkControl_OnRender" Ready="OpenTkControl_OnReady"/>

        <!-- Панель статуса игроков -->
        <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10" Padding="10" Background="#88000000" CornerRadius="5" IsHitTestVisible="False">
            <StackPanel>
                <TextBlock Text="СТАТУС ИГРОКОВ" Foreground="White" FontWeight="Bold" Margin="0,0,0,5" HorizontalAlignment="Center"/>
                
                <TextBlock x:Name="TxtTotalTreasures" Text="Сокровищ на карте: 0" Foreground="Gold" FontSize="12" Margin="0,0,0,8" HorizontalAlignment="Center"/>

                <StackPanel Orientation="Vertical" Margin="0,2">
                    <TextBlock Text="Игрок 1 (Красный):" Foreground="#FF5555" FontWeight="Bold" FontSize="11"/>
                    <TextBlock x:Name="TxtP1Status" Text="Скор: 100%, Заряды: 0, Счет: 0" Foreground="White" Margin="5,0,0,5"/>
                </StackPanel>

                <StackPanel Orientation="Vertical" Margin="0,2">
                    <TextBlock Text="Игрок 2 (Синий):" Foreground="#5555FF" FontWeight="Bold" FontSize="11"/>
                    <TextBlock x:Name="TxtP2Status" Text="Скор: 100%, Заряды: 0, Счет: 0" Foreground="White" Margin="5,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Главное меню -->
        <Grid x:Name="MainMenuGrid" Background="#DD000000">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="200">
                <TextBlock Text="КЛАД" FontSize="36" FontWeight="Bold" Foreground="Gold" TextAlignment="Center" Margin="0,0,0,30"/>
                <Button Content="Начать игру" FontSize="18" Margin="0,5" Padding="10" Click="BtnStartGame_Click"/>
                <Button Content="Справка" FontSize="18" Margin="0,5" Padding="10" Click="BtnHelp_Click"/>
                <Button Content="Настройки" FontSize="18" Margin="0,5" Padding="10" Click="BtnSettings_Click"/>
                <Button Content="Выход" FontSize="18" Margin="0,5" Padding="10" Click="BtnExit_Click"/>
            </StackPanel>
        </Grid>

        <!-- Меню справки (Правила) -->
        <Grid x:Name="HelpMenuGrid" Background="#EE000000" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="550">
                <TextBlock Text="Правила игры" FontSize="28" FontWeight="Bold" Foreground="White" TextAlignment="Center" Margin="0,0,0,15"/>
                
                <TextBlock Foreground="White" FontSize="15" TextWrapping="Wrap" Margin="0,0,0,10">
                    <Run FontWeight="Bold" Foreground="Gold" Text="Цель игры: "/>
                    Соберите больше половины сокровищ быстрее оппонента! Если сокровищ четное количество и счет равен, объявляется ничья.
                </TextBlock>
                
                <TextBlock Foreground="White" FontSize="15" TextWrapping="Wrap" Margin="0,0,0,10">
                    <Run FontWeight="Bold" Foreground="Lime" Text="Управление:"/><LineBreak/>
                    - <Run Foreground="#FF5555" Text="Игрок 1 (Красный): "/> WASD для перемещения. Пробел (Space) для взаимодействия со стеной.<LineBreak/>
                    - <Run Foreground="#5555FF" Text="Игрок 2 (Синий): "/> Стрелочки для перемещения. Enter для взаимодействия со стеной.
                </TextBlock>

                <TextBlock Foreground="White" FontSize="15" TextWrapping="Wrap" Margin="0,0,0,20">
                    <Run FontWeight="Bold" Foreground="Orange" Text="Игровые объекты:"/><LineBreak/>
                    - <Run Foreground="Yellow" Text="Желтые квадраты (Сокровища): "/> Дают очки для победы.<LineBreak/>
                    - <Run Foreground="Lime" Text="Зеленые квадраты (Призы): "/> Случайным образом изменяют скорость (ускорение/замедление) или дают заряд для стены.<LineBreak/>
                    - <Run Foreground="Gray" Text="Серые квадраты (Стены): "/> Непроходимые препятствия.<LineBreak/>
                    <Run FontWeight="Bold" Text="Заряд для стены: "/> Позволяет установить временную стену перед собой (на пустой клетке) или сломать уже стоящую стену!
                </TextBlock>

                <Button Content="Назад в меню" FontSize="18" Padding="10" Click="BtnBackFromHelp_Click" Width="200"/>
            </StackPanel>
        </Grid>

        <!-- Меню настроек -->
        <Grid x:Name="SettingsMenuGrid" Background="#EE000000" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="300">
                <TextBlock Text="Настройки Сессии" FontSize="24" FontWeight="Bold" Foreground="White" TextAlignment="Center" Margin="0,0,0,20"/>
                
                <TextBlock Text="Количество сокровищ:" Foreground="White" FontSize="14"/>
                <TextBox x:Name="TbTreasures" Text="15" FontSize="16" Margin="0,5,0,15" TextAlignment="Center"/>

                <TextBlock Text="Количество призов:" Foreground="White" FontSize="14"/>
                <TextBox x:Name="TbPrizes" Text="10" FontSize="16" Margin="0,5,0,20" TextAlignment="Center"/>

                <Button Content="Сохранить и Назад" FontSize="18" Padding="10" Click="BtnSaveSettings_Click"/>
            </StackPanel>
        </Grid>

        <!-- Экран завершения игры -->
        <Grid x:Name="GameOverGrid" Background="#DD000000" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="TbWinnerText" Text="Победил Игрок 1!" FontSize="32" FontWeight="Bold" Foreground="Lime" TextAlignment="Center" Margin="0,0,0,20"/>
                <Button Content="В Главное Меню" FontSize="18" Padding="10" Click="BtnBackToMenu_Click" Width="200"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
